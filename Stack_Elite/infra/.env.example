# ==========================================
# ELITE SDR STACK — Environment Variables
# Copie para .env e preencha TODOS os valores antes de fazer deploy.
# Nunca commite o .env no Git!
# ==========================================

# ── Domínio e Rede
DOMAIN_NAME=seudominio.com.br
SUBDOMAIN=n8n
ACME_EMAIL=seu@email.com.br        # E-mail para certificados Let's Encrypt

# ── Segredo do Webhook (n8n → Chatwoot)
WEBHOOK_SECRET=gere_com__openssl_rand_hex_32

# ── Postgres (pgvector) ─ TODOS os hosts devem usar "elite_postgres"
POSTGRES_USER=elite_admin
POSTGRES_PASSWORD=troque_por_senha_muito_segura
POSTGRES_DB=elite_sdr_db
DATABASE_URL=postgresql://elite_admin:troque_por_senha_muito_segura@elite_postgres:5432/elite_sdr_db

# ── Redis  ─ HOST interno: elite_redis
REDIS_PASSWORD=troque_por_outra_senha_segura

# ── n8n
N8N_ENCRYPTION_KEY=gere_com__openssl_rand_hex_32

# ── Chatwoot MCP
CHATWOOT_URL=https://chat.seudominio.com.br
CHATWOOT_API_KEY=seu_bot_token_chatwoot
CHATWOOT_ACCOUNT_ID=1

# ── LLMs & Observabilidade
GEMINI_API_KEY=AIzaSy...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_SALT=gere_com__openssl_rand_hex_32
LANGFUSE_NEXTAUTH_SECRET=gere_com__openssl_rand_hex_32

# ── Google Calendar (mcp-scheduling) \u2014 GRATUITO (1M requests/dia)
# Serve para: criar eventos reais no Google Agenda do vendedor quando um lead agenda test-drive.
# Obtenha as credenciais via: https://developers.google.com/oauthplayground
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//...           # Obtido via OAuth2 Playground (veja guia)
# GOOGLE_MAPS_API_KEY \u2014 N\u00c3O NECESS\u00c1RIO: o link de localiza\u00e7\u00e3o \u00e9 uma URL simples, sem custo

# ── AI Services — URLs internas (sem alterar se usar docker-compose padrão)
RAG_SERVICE_URL=http://ai_rag:8000
WHISPER_URL=http://ai_whisper:9000
LLAVA_URL=http://ai_llava:8000
GLINER_URL=http://ai_gliner:8000
SECURITY_URL=http://ai_security:8000
SENTIMENT_URL=http://ai_sentiment:8000

# ── Ollama (para LLaVA) — sobe separado
OLLAMA_URL=http://ollama:11434
LLAVA_MODEL=llava
